# Mẫu cấu hình môi trường
# Sao chép tệp này sang .env và cập nhật các giá trị

# ===========================
# CẤU HÌNH MÁY CHỦ
# ===========================
PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# ===========================
# CẤU HÌNH CƠSỞ DỮ LIỆU
# ===========================
# Cho MongoDB cục bộ
MONGODB_URI=mongodb://localhost:27017/luxury_jewelry

# Cho MongoDB Atlas (Đám mây)
# Bỏ ghi chú và thay thế thông tin đăng nhập bên dưới
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/luxury_jewelry

# ===========================
# CẤU HÌNH JWT
# ===========================
# QUAN TRỌNG: Thay đổi thành chuỗi mạnh, ngẫu nhiên trong phát hành sản phẩm
# Bạn có thể tạo một chuỗi bằng cách sử dụng: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345678
JWT_EXPIRE=7d

# ===========================
# CẤU HÌNH EMAIL / SMTP
# ===========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
# URL logo public cho email (khuyến nghị dùng CDN/domain tĩnh)
EMAIL_LOGO_URL=https://cdn.jsdelivr.net/gh/HuyVoTran/Advanced-Web-Programming@main/client/public/images/SalvioRoyale-Logo.png

# ===========================
# CẤU HÌNH TẢI LÊN FILE (Tùy chọn - để sử dụng trong tương lai)
# ===========================
# CLOUDINARY_NAME=your-cloudinary-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ===========================
# CỔNG THANH TOÁN (Tùy chọn - để sử dụng trong tương lai)
# ===========================
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...

GOOGLE_CLIENT_ID=